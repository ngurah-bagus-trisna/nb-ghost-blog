---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PostCard from '../components/PostCard.astro';
import ImageLightbox from '../components/ImageLightbox.astro';
import TableOfContents from '../components/TableOfContents.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
  relatedPosts: CollectionEntry<'posts'>[];
}

const { post, relatedPosts } = Astro.props;
const { data } = post;

const dateStr = data.published.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const tags = data.tags || [];
const hasHero = !!data.featuredImage;

const siteUrl = Astro.site?.href.replace(/\/$/, '') || 'https://twnb.nbtrisna.my.id';
const articleUrl = new URL(`/${data.slug}/`, Astro.site).href;
const primaryTag = tags[0] || null;
---

<BaseLayout
  title={data.title}
  description={data.excerpt || undefined}
  ogImage={data.featuredImage}
  ogType="article"
  canonicalURL={new URL(`/${data.slug}/`, Astro.site).href}
  bodyClass="post-template"
  publishedTime={data.published.toISOString()}
  modifiedTime={data.updated?.toISOString()}
  tags={tags}
  author={data.author}
>
  <Header currentPath={`/${data.slug}/`} />

  <main class="gh-main">
    {hasHero ? (
      <div class="post-hero">
        <div class="post-hero-bg" style={`background-image: url(${data.featuredImage})`}></div>
        <div class="post-hero-overlay"></div>
        <div class="post-hero-content">
          {tags.length > 0 && (
            <div class="post-hero-tags">
              {tags.map(tag => (
                <a class="post-hero-tag" href={`/tag/${tag}/`}>{tag}</a>
              ))}
            </div>
          )}
          <h1 class="post-hero-title">{data.title}</h1>
          <div class="post-hero-meta">
            <span>{data.author}</span>
            <span class="post-hero-sep">&middot;</span>
            <time datetime={data.published.toISOString()}>{dateStr}</time>
          </div>
        </div>
      </div>
    ) : (
      <header class="post-header-plain">
        {tags.length > 0 && (
          <div class="post-header-tags">
            {tags.map(tag => (
              <a class="post-header-tag" href={`/tag/${tag}/`}>{tag}</a>
            ))}
          </div>
        )}
        <h1 class="gh-article-title is-title">{data.title}</h1>
        <div class="gh-article-meta">
          <div class="gh-article-meta-wrapper">
            <span class="gh-article-author-name">{data.author}</span>
            <div class="gh-article-meta-content">
              <time datetime={data.published.toISOString()}>{dateStr}</time>
            </div>
          </div>
        </div>
      </header>
    )}

    <div class="post-body-wrap">
      <div class="post-body-main">
        <section class="gh-content gh-canvas is-body">
          <slot />
        </section>

        {relatedPosts.length > 0 && (
          <section class="gh-container is-grid gh-outer">
            <div class="gh-container-inner gh-inner">
              <h2 class="gh-container-title">Read more</h2>
              <div class="gh-feed">
                {relatedPosts.slice(0, 4).map(p => (
                  <PostCard post={p} />
                ))}
              </div>
            </div>
          </section>
        )}
      </div>
      <TableOfContents />
    </div>
  </main>

  <Footer />
  <ImageLightbox />

  <!-- JSON-LD Article + BreadcrumbList -->
  <script type="application/ld+json">
    {JSON.stringify({
    '@context': 'https://schema.org',
    '@graph': [
      {
        '@type': 'BlogPosting',
        '@id': `${articleUrl}#article`,
        headline: data.title,
        description: data.excerpt || '',
        url: articleUrl,
        datePublished: data.published.toISOString(),
        dateModified: (data.updated || data.published).toISOString(),
        author: {
          '@type': 'Person',
          '@id': `${siteUrl}/#person`,
          name: data.author,
        },
        image: data.featuredImage || undefined,
        publisher: {
          '@id': `${siteUrl}/#organization`,
        },
        keywords: tags.join(', '),
        inLanguage: 'id',
        isPartOf: {
          '@id': `${siteUrl}/#website`,
        },
      },
      {
        '@type': 'BreadcrumbList',
        itemListElement: [
          { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
          ...(primaryTag ? [{
            '@type': 'ListItem' as const,
            position: 2,
            name: primaryTag,
            item: `${siteUrl}/tag/${primaryTag}/`,
          }] : []),
          { '@type': 'ListItem', position: primaryTag ? 3 : 2, name: data.title },
        ],
      },
    ],
  })}
  </script>
</BaseLayout>

<style>
  .post-hero {
    position: relative;
    height: 55vh;
    min-height: 360px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    margin-bottom: clamp(40px, 5vw, 64px);
  }

  .post-hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
  }

  .post-hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to top, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.15) 50%, rgba(0,0,0,0.3) 100%),
      linear-gradient(to right, rgba(0,0,0,0.35) 0%, transparent 60%);
    z-index: 1;
  }

  .post-hero-content {
    position: relative;
    z-index: 2;
    padding: 0 max(4vmin, 40px) max(4vmin, 40px);
    max-width: 800px;
  }

  .post-hero-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }

  .post-hero-tag {
    display: inline-block;
    font-size: 1.2rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--ghost-accent-color, #b6bdff);
    text-decoration: none;
    padding: 4px 0;
  }

  .post-hero-tag:hover {
    color: #fff;
  }

  .post-hero-tag + .post-hero-tag::before {
    content: ' · ';
    color: rgba(255,255,255,0.4);
    margin-right: 8px;
  }

  .post-hero-title {
    font-family: var(--gh-font-heading, 'Noto Sans'), sans-serif;
    font-size: clamp(2.2rem, 4vw, 3.8rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #fff;
    margin: 0 0 0.6em;
    text-shadow: 0 2px 12px rgba(0,0,0,0.4);
  }

  .post-hero-meta {
    font-size: 1.4rem;
    color: rgba(255,255,255,0.7);
    font-weight: 500;
  }

  .post-hero-sep {
    margin: 0 8px;
    opacity: 0.5;
  }

  /* Plain header for posts without hero image */
  .post-header-plain {
    padding: 140px max(4vmin, 40px) 0;
    margin: 0 auto 40px;
    max-width: var(--container-width, 1320px);
  }

  .post-header-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }

  .post-header-tag {
    font-size: 1.2rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--ghost-accent-color, #b6bdff);
    text-decoration: none;
  }

  .post-header-tag:hover {
    opacity: 0.8;
  }

  .post-body-wrap {
    display: flex;
    gap: 40px;
    max-width: var(--container-width, 1320px);
    margin: 0 auto;
    padding: 0 max(4vmin, 40px);
    align-items: flex-start;
  }

  .post-body-main {
    flex: 1;
    min-width: 0;
  }

  @media (max-width: 1199px) {
    .post-body-wrap {
      flex-direction: column;
    }
  }

  @media (max-width: 640px) {
    .post-hero {
      height: 50vh;
      min-height: 260px;
      width: 100%;
      max-width: 100vw;
    }
    .post-hero-bg {
      max-width: 100vw;
    }
    .post-hero-content {
      padding: 0 20px 24px;
      max-width: 100%;
    }
    .post-hero-title {
      font-size: 1.8rem;
      word-break: break-word;
    }
    .post-hero-meta {
      font-size: 1.2rem;
    }
    .post-header-plain {
      padding: 100px 20px 0;
    }
    .post-body-wrap {
      padding: 0 16px;
      gap: 24px;
      max-width: 100vw;
    }
    .gh-content { padding: 0; word-break: break-word; }
    .gh-content pre, .gh-content table { max-width: calc(100vw - 32px); }
  }
</style>
