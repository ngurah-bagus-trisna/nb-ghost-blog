---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PostCard from '../components/PostCard.astro';
import { getTagDescription } from '../utils/tags';
import type { CollectionEntry } from 'astro:content';

interface Props {
  tag: string;
  posts: CollectionEntry<'posts'>[];
}

const { tag, posts } = Astro.props;
const title = `${tag} - twnb`;
const description = getTagDescription(tag);
---

<BaseLayout
  title={title}
  bodyClass="tag-template"
  canonicalURL={new URL(`/tag/${tag}/`, Astro.site).href}
>
  <Header currentPath={`/tag/${tag}/`} />

  <main class="gh-main">
    <div class="gh-archive gh-outer">
      <div class="gh-archive-inner gh-inner">
        <div class="gh-archive-wrapper">
          <h2 class="gh-article-title is-title">{tag}</h2>
          {description && (
            <p class="gh-article-excerpt">{description}</p>
          )}
          <div class="gh-author-meta">
            <span>{posts.length} post{posts.length !== 1 ? 's' : ''}</span>
          </div>
        </div>
      </div>
    </div>

    <section class="gh-container is-grid gh-outer">
      <div class="gh-container-inner gh-inner">
        <main class="gh-main">
          <div class="gh-feed">
            {posts.map(post => <PostCard post={post} />)}
          </div>
        </main>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
