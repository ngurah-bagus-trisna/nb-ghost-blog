---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PostCard from '../components/PostCard.astro';
import HeroSlideshow from '../components/HeroSlideshow.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'posts'>[];
  heroPosts?: CollectionEntry<'posts'>[];
}

const { posts, heroPosts } = Astro.props;
const title = 'Tech with Ngurah Bagus: IT Notes, Tutorials, and My Journey';
---

<BaseLayout
  title={title}
  bodyClass="home-template"
  canonicalURL={new URL('/', Astro.site).href}
>
  <Header currentPath="/" />

  {heroPosts && heroPosts.length > 0 && <HeroSlideshow posts={heroPosts} />}

  <section class="gh-container is-grid no-image gh-outer">
    <div class="gh-container-inner gh-inner">
      <h2 class="gh-container-title">Latest</h2>
      <main class="gh-main">
        <div class="gh-feed">
          {posts.map(post => <PostCard post={post} />)}
        </div>
      </main>
    </div>
  </section>

  <Footer />

  {/* JSON-LD CollectionPage */}
  <script type="application/ld+json">
    {JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    '@id': `${new URL('/', Astro.site).href}#collection`,
    name: title,
    description: 'Latest articles and tutorials on Linux, KVM, AWS, Kubernetes, and DevOps.',
    url: new URL('/', Astro.site).href,
    isPartOf: { '@id': `${new URL('/', Astro.site).href}#website` },
  })}
  </script>
</BaseLayout>
