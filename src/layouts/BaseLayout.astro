---
export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonicalURL?: string;
  bodyClass?: string;
  publishedTime?: string;
  modifiedTime?: string;
  tags?: string[];
  noIndex?: boolean;
}

const {
  title,
  description = 'Explore the world of IT with Ngurah Bagus. Read insightful notes, follow step-by-step tutorials, and join my journey in the IT World :)',
  ogImage,
  ogType = 'website',
  canonicalURL = Astro.url.href,
  bodyClass = 'home-template',
  publishedTime,
  modifiedTime,
  tags = [],
  noIndex = false,
} = Astro.props;

const siteTitle = 'twnb';
const siteUrl = Astro.site?.href.replace(/\/$/, '') || 'https://twnb.nbtrisna.my.id';
const accentColor = '#b6bdff';
const backgroundColor = '#151515';
---

<!DOCTYPE html>
<html class="has-light-text" lang="id">
<head>
  <title>{title}</title>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>

  <link rel="preload" as="style" href="/assets/built/screen.css">
  <link rel="preload" as="font" type="font/woff2" href="/assets/fonts/inter-roman.woff2" crossorigin="anonymous">

  <style>
    @font-face {
      font-family: "Inter";
      font-style: normal;
      font-weight: 100 900;
      font-display: optional;
      src: url(/assets/fonts/inter-roman.woff2) format("woff2");
      unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+2074, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
    }
  </style>

  <link rel="stylesheet" type="text/css" href="/assets/built/screen.css">

  <link rel="preconnect" href="https://fonts.bunny.net">
  <link rel="stylesheet" href="https://fonts.bunny.net/css?family=noto-sans:400,700|space-mono:400,700">

  <style is:global>
    :root {
      --background-color: #151515;
      --ghost-accent-color: #b6bdff;
      --gh-font-heading: Noto Sans;
      --gh-font-body: Space Mono;
    }
  </style>

  <link rel="icon" href="/content/images/size/w256h256/2023/12/Logo-CHannel-1.png" type="image/png">
  <link rel="canonical" href={canonicalURL}>
  <meta name="referrer" content="no-referrer-when-downgrade">

  <meta property="og:site_name" content={siteTitle}>
  <meta property="og:type" content={ogType}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:url" content={canonicalURL}>
  {publishedTime && <meta property="article:published_time" content={publishedTime}>}
  {modifiedTime && <meta property="article:modified_time" content={modifiedTime}>}
  {ogImage && <meta property="og:image" content={ogImage}>}
  {tags.map(tag => <meta property="article:tag" content={tag}>)}
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:url" content={canonicalURL}>

  {noIndex && <meta name="robots" content="noindex">}

  <link rel="alternate" type="application/rss+xml" title={siteTitle} href={`${siteUrl}/rss.xml`}>

  <link href="https://unpkg.com/dracula-prism/dist/css/dracula-prism.css" rel="stylesheet">
  <script src="https://unpkg.com/prismjs@1.29.0/prism.js" defer></script>
  <script src="https://unpkg.com/prismjs@1.29.0/plugins/autoloader/prism-autoloader.min.js" defer></script>
  <style is:global>
    pre[class*="language-"] {
      border-radius: 8px;
      margin: 1.5em 0;
      font-size: 0.9em;
    }
    code[class*="language-"] {
      font-family: "JetBrains Mono", Menlo, Consolas, Monaco, "Liberation Mono", "Lucida Console", monospace;
    }
  </style>
</head>

<body class={`${bodyClass} gh-font-heading-noto-sans gh-font-body-space-mono has-sans-title has-sans-body`}>
  <div class="gh-viewport">
    <slot />
  </div>

  <script is:inline src="/assets/built/source.js"></script>
</body>
</html>
