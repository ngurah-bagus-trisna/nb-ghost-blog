---
interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

interface NavItem { label: string; href: string; slug: string; }

const navItems: NavItem[] = [
  { label: 'Home', href: '/', slug: 'home' },
  { label: 'Daily Notes', href: '/tag/daily-notes/', slug: 'daily-notes' },
  { label: 'Blog', href: '/tag/catatan/', slug: 'blog' },
  { label: 'About', href: '/about/', slug: 'about' },
];

function isCurrent(item: NavItem): boolean {
  if (item.href === '/') return currentPath === '/';
  return currentPath.startsWith(item.href);
}
---

<header id="gh-navigation" class="gh-navigation is-left-logo gh-outer nav-transparent">
  <div class="gh-navigation-inner gh-inner">
    <div class="gh-navigation-brand">
      <a class="gh-navigation-logo is-title" href="/">
        <img src="/content/images/2024/08/logo-Primary-1.png" alt="twnb">
      </a>
      <button class="gh-search gh-icon-button search-toggle" aria-label="Search this site" data-open-search>
        <img src="/assets/images/search.svg" alt="Search" width="20" height="20">
      </button>
      <button class="gh-burger gh-icon-button" aria-label="Menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 256 256"><path d="M224,128a8,8,0,0,1-8,8H40a8,8,0,0,1,0-16H216A8,8,0,0,1,224,128ZM40,72H216a8,8,0,0,0,0-16H40a8,8,0,0,0,0,16ZM216,184H40a8,8,0,0,0,0,16H216a8,8,0,0,0,0-16Z"></path></svg>
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 256 256"><path d="M205.66,194.34a8,8,0,0,1-11.32,11.32L128,139.31,61.66,205.66a8,8,0,0,1-11.32-11.32L116.69,128,50.34,61.66A8,8,0,0,1,61.66,50.34L128,116.69l66.34-66.35a8,8,0,0,1,11.32,11.32L139.31,128Z"></path></svg>
      </button>
    </div>

    <nav class="gh-navigation-menu">
      <ul class="nav">
        {navItems.map(item => (
          <li class={`nav-${item.slug}${isCurrent(item) ? ' nav-current' : ''}`}>
            <a href={item.href}>{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="gh-navigation-actions">
      <button class="gh-search gh-icon-button search-toggle" aria-label="Search this site" data-open-search>
        <img src="/assets/images/search.svg" alt="Search" width="20" height="20">
      </button>
    </div>
  </div>
</header>

<div class="search-overlay" id="search-overlay">
  <div class="search-modal">
    <div class="search-header">
      <button class="search-close" id="search-close" aria-label="Close search">&times;</button>
    </div>
    <div id="pagefind-search"></div>
  </div>
</div>

<link href="/pagefind/pagefind-ui.css" rel="stylesheet">
<script src="/pagefind/pagefind-ui.js" is:inline></script>

<style>
  .nav-transparent {
    background-color: transparent !important;
    transition: background-color 0.35s ease, box-shadow 0.35s ease;
  }

  .nav-transparent.scrolled {
    background-color: var(--background-color, #151515) !important;
    box-shadow: 0 1px 0 var(--color-border, rgba(255,255,255,0.08));
  }

  .gh-navigation {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
  }

  .gh-search img {
    display: block;
    background: none;
    border: none;
    outline: none;
  }

  .search-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(10,10,10,0.72);
    display: none;
    align-items: flex-start;
    justify-content: center;
    padding: 12vh 24px 0;
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    overflow-y: auto;
  }

  .search-overlay.open {
    display: flex;
  }

  .search-modal {
    width: 100%;
    max-width: 600px;
  }

  .search-header {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 12px;
  }

  .search-close {
    background: none;
    border: none;
    color: rgba(255,255,255,0.5);
    font-size: 2.4rem;
    cursor: pointer;
    padding: 4px 8px;
    line-height: 1;
  }

  .search-close:hover {
    color: #fff;
  }

  /* Pagefind UI dark theme overrides */
  #pagefind-search {
    --pagefind-ui-primary: #fff;
    --pagefind-ui-text: rgba(255,255,255,0.9);
    --pagefind-ui-background: rgba(255,255,255,0.04);
    --pagefind-ui-border: rgba(255,255,255,0.12);
    --pagefind-ui-tag: rgba(255,255,255,0.06);
    --pagefind-ui-font: var(--gh-font-body, 'Space Mono'), monospace;
  }

  #pagefind-search input {
    background: rgba(255,255,255,0.06) !important;
    border: 1px solid rgba(255,255,255,0.12) !important;
    color: #fff !important;
    border-radius: 10px !important;
    padding: 12px 16px !important;
    font-size: 1.5rem !important;
  }

  #pagefind-search input::placeholder {
    color: rgba(255,255,255,0.35) !important;
  }

  #pagefind-search input:focus {
    border-color: var(--ghost-accent-color, #b6bdff) !important;
  }

  #pagefind-search .pagefind-ui__result-title {
    color: #fff !important;
  }

  #pagefind-search .pagefind-ui__result-excerpt {
    color: rgba(255,255,255,0.65) !important;
  }

  #pagefind-search .pagefind-ui__result-link {
    color: var(--ghost-accent-color, #b6bdff) !important;
  }

  #pagefind-search mark,
  #pagefind-search .pagefind-ui__result-excerpt mark {
    background: var(--ghost-accent-color, #b6bdff) !important;
    color: #151515 !important;
    padding: 1px 4px !important;
    border-radius: 3px !important;
  }

  #pagefind-search .pagefind-ui__message {
    color: rgba(255,255,255,0.5) !important;
  }

  #pagefind-search .pagefind-ui__button {
    background: rgba(255,255,255,0.08) !important;
    color: #fff !important;
    border: 1px solid rgba(255,255,255,0.12) !important;
  }
</style>

<script>
  (function() {
    var overlay = document.getElementById('search-overlay');
    var closeBtn = document.getElementById('search-close');
    if (!overlay || !closeBtn) return;

    var pagefindUI = null;

    function open() {
      overlay.classList.add('open');
      if (!pagefindUI) {
        var el = document.getElementById('pagefind-search');
        if (el && window.PagefindUI) {
          pagefindUI = new window.PagefindUI({
            element: '#pagefind-search',
            showSubResults: true,
            showImages: false,
          });
        }
      }
    }
    function close() {
      overlay.classList.remove('open');
    }

    document.querySelectorAll('[data-open-search]').forEach(function(btn) {
      btn.addEventListener('click', open);
    });
    closeBtn.addEventListener('click', close);
    overlay.addEventListener('click', function(e) {
      if (e.target === overlay) close();
    });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && overlay.classList.contains('open')) close();
    });
  })();
</script>

<script>
  (function() {
    var nav = document.getElementById('gh-navigation');
    if (!nav) return;
    function onScroll() {
      if (window.scrollY > 50) {
        nav.classList.add('scrolled');
      } else {
        nav.classList.remove('scrolled');
      }
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  })();
</script>
