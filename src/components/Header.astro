---
interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

interface NavItem { label: string; href: string; slug: string; }

const navItems: NavItem[] = [
  { label: 'Home', href: '/', slug: 'home' },
  { label: 'Daily Notes', href: '/tag/daily-notes/', slug: 'daily-notes' },
  { label: 'Blog', href: '/tag/catatan/', slug: 'blog' },
  { label: 'About', href: '/about/', slug: 'about' },
];

function isCurrent(item: NavItem): boolean {
  if (item.href === '/') return currentPath === '/';
  return currentPath.startsWith(item.href);
}
---

<header id="gh-navigation" class="gh-navigation is-left-logo gh-outer nav-transparent">
  <div class="gh-navigation-inner gh-inner">
    <div class="gh-navigation-brand">
      <a class="gh-navigation-logo is-title" href="/">
        <img src="/content/images/2024/08/logo-Primary-1.png" alt="twnb">
      </a>
      <button class="gh-search gh-icon-button search-toggle" aria-label="Search this site" data-open-search>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="#ffffff" viewBox="0 0 16 16"><path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0"/></svg>
      </button>
      <button class="burger-btn" id="burger-btn" aria-label="Menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="#ffffff" viewBox="0 0 256 256"><path d="M224,128a8,8,0,0,1-8,8H40a8,8,0,0,1,0-16H216A8,8,0,0,1,224,128ZM40,72H216a8,8,0,0,0,0-16H40a8,8,0,0,0,0,16ZM216,184H40a8,8,0,0,0,0,16H216a8,8,0,0,0,0-16Z"/></svg>
      </button>
    </div>

    <nav class="gh-navigation-menu">
      <ul class="nav">
        {navItems.map(item => (
          <li class={`nav-${item.slug}${isCurrent(item) ? ' nav-current' : ''}`}>
            <a href={item.href}>{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="gh-navigation-actions">
      <button class="gh-search gh-icon-button search-toggle" aria-label="Search this site" data-open-search>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="#ffffff" viewBox="0 0 16 16"><path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile nav -->
  <div class="mob-nav" id="mob-nav">
    <button class="mob-nav-close" id="mob-nav-close" aria-label="Close">&times;</button>
    <ul class="mob-nav-list">
      {navItems.map(item => (
        <li><a href={item.href} class:list={[{ 'mob-nav-current': isCurrent(item) }]}>{item.label}</a></li>
      ))}
    </ul>
  </div>
</header>

<!-- Search overlay -->
<div class="search-overlay" id="search-overlay">
  <div class="search-modal">
    <div class="search-header">
      <button class="search-close" id="search-close" aria-label="Close search">&times;</button>
    </div>
    <div id="pagefind-search"></div>
  </div>
</div>

<link href="/pagefind/pagefind-ui.css" rel="stylesheet">
<script src="/pagefind/pagefind-ui.js" is:inline></script>

<style>
  /* Navbar base */
  .nav-transparent,
  .nav-transparent :is(a, button, span) {
    color: #fff !important;
  }
  .nav-transparent {
    background-color: transparent !important;
    transition: background-color 0.35s ease, box-shadow 0.35s ease;
  }
  .nav-transparent.scrolled {
    background-color: var(--background-color, #151515) !important;
    box-shadow: 0 1px 0 var(--color-border, rgba(255,255,255,0.08));
  }
  .gh-navigation {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  }

  /* Search button */
  .search-toggle,
  .search-toggle:hover,
  .search-toggle:focus,
  .search-toggle:active {
    background: transparent !important; border: 0 !important;
    outline: 0 !important; box-shadow: none !important; color: #fff !important;
  }
  .search-toggle svg { display: block; width: 20px; height: 20px; }

  /* Burger button */
  .burger-btn {
    display: flex; align-items: center; justify-content: center;
    background: transparent; border: 0; cursor: pointer;
    padding: 0; width: 32px; height: 32px; color: #fff;
  }
  @media (min-width: 768px) {
    .burger-btn { display: none; }
  }

  /* Mobile nav overlay */
  .mob-nav {
    display: block;
    position: fixed; inset: 0; z-index: 999;
    background: var(--background-color, #151515);
    padding: 100px 32px 40px;
    opacity: 0; visibility: hidden; pointer-events: none;
    transition: opacity 0.25s, visibility 0.25s;
  }
  .mob-nav.open {
    opacity: 1; visibility: visible; pointer-events: auto;
  }
  .mob-nav-list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 20px;
  }
  .mob-nav-list a {
    font-family: var(--gh-font-heading, 'Noto Sans'), sans-serif;
    font-size: 2.2rem; font-weight: 650; color: #fff;
    text-decoration: none; display: block; padding: 8px 0;
  }
  .mob-nav-list a.mob-nav-current {
    color: var(--ghost-accent-color, #b6bdff);
  }
  .mob-nav-close {
    position: absolute; top: 20px; right: 24px;
    background: none; border: none; color: #fff;
    font-size: 3rem; cursor: pointer; line-height: 1;
    opacity: 0.6; z-index: 1;
  }
  .mob-nav-close:hover { opacity: 1; }
  @media (min-width: 768px) {
    .mob-nav, .mob-nav.open { display: none !important; }
  }

  /* Search overlay */
  .search-overlay {
    position: fixed; inset: 0; z-index: 9999;
    background: rgba(10,10,10,0.72);
    display: none; align-items: flex-start; justify-content: center;
    padding: 12vh 24px 0;
    backdrop-filter: blur(18px); -webkit-backdrop-filter: blur(18px);
    overflow-y: auto;
  }
  .search-overlay.open { display: flex; }
  .search-modal { width: 100%; max-width: 600px; }
  .search-header { display: flex; justify-content: flex-end; margin-bottom: 12px; }
  .search-close {
    background: none; border: none; color: rgba(255,255,255,0.5);
    font-size: 2.4rem; cursor: pointer; padding: 4px 8px; line-height: 1;
  }
  .search-close:hover { color: #fff; }

  /* Pagefind dark theme */
  #pagefind-search {
    --pagefind-ui-primary: #fff;
    --pagefind-ui-text: rgba(255,255,255,0.9);
    --pagefind-ui-background: rgba(255,255,255,0.04);
    --pagefind-ui-border: rgba(255,255,255,0.12);
    --pagefind-ui-tag: rgba(255,255,255,0.06);
    --pagefind-ui-font: var(--gh-font-body, 'Space Mono'), monospace;
  }
  #pagefind-search input {
    background: rgba(255,255,255,0.06) !important;
    border: 1px solid rgba(255,255,255,0.12) !important;
    color: #fff !important; border-radius: 10px !important;
    padding: 12px 16px !important; font-size: 1.5rem !important;
  }
  #pagefind-search input::placeholder { color: rgba(255,255,255,0.35) !important; }
  #pagefind-search input:focus { border-color: var(--ghost-accent-color, #b6bdff) !important; }
  #pagefind-search .pagefind-ui__result-title { color: #fff !important; }
  #pagefind-search .pagefind-ui__result-excerpt { color: rgba(255,255,255,0.65) !important; }
  #pagefind-search .pagefind-ui__result-link { color: var(--ghost-accent-color, #b6bdff) !important; }
  #pagefind-search mark,
  #pagefind-search .pagefind-ui__result-excerpt mark {
    background: var(--ghost-accent-color, #b6bdff) !important;
    color: #151515 !important; padding: 1px 4px !important; border-radius: 3px !important;
  }
  #pagefind-search .pagefind-ui__message { color: rgba(255,255,255,0.5) !important; }
  #pagefind-search .pagefind-ui__button {
    background: rgba(255,255,255,0.08) !important; color: #fff !important;
    border: 1px solid rgba(255,255,255,0.12) !important;
  }
</style>

<script>
  (function() {
    // ── Navbar scroll background ──
    var nav = document.getElementById('gh-navigation');
    if (nav) {
      function onScroll() {
        nav.classList.toggle('scrolled', window.scrollY > 50);
      }
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    }

    // ── Burger / mobile nav ──
    var burger = document.getElementById('burger-btn');
    var mobNav = document.getElementById('mob-nav');
    var mobClose = document.getElementById('mob-nav-close');

    if (burger && mobNav) {
      function openMob() {
        mobNav.classList.add('open');
        document.body.style.overflow = 'hidden';
      }
      function closeMob() {
        mobNav.classList.remove('open');
        document.body.style.overflow = '';
      }

      burger.addEventListener('click', function() {
        mobNav.classList.contains('open') ? closeMob() : openMob();
      });

      if (mobClose) mobClose.addEventListener('click', closeMob);

      mobNav.addEventListener('click', function(e) {
        if (e.target === mobNav) closeMob();
      });

      mobNav.querySelectorAll('a').forEach(function(link) {
        link.addEventListener('click', closeMob);
      });

      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && mobNav.classList.contains('open')) closeMob();
      });
    }

    // ── Search overlay ──
    var searchOverlay = document.getElementById('search-overlay');
    var searchClose = document.getElementById('search-close');
    if (searchOverlay && searchClose) {
      var pagefindUI = null;

      function openSearch() {
        searchOverlay.classList.add('open');
        if (!pagefindUI) {
          var el = document.getElementById('pagefind-search');
          if (el && window.PagefindUI) {
            pagefindUI = new window.PagefindUI({
              element: '#pagefind-search',
              showSubResults: true,
              showImages: false,
            });
          }
        }
      }
      function closeSearch() { searchOverlay.classList.remove('open'); }

      document.querySelectorAll('[data-open-search]').forEach(function(btn) {
        btn.addEventListener('click', openSearch);
      });
      searchClose.addEventListener('click', closeSearch);
      searchOverlay.addEventListener('click', function(e) {
        if (e.target === searchOverlay) closeSearch();
      });
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && searchOverlay.classList.contains('open')) closeSearch();
      });
    }
  })();
</script>
