<aside class="toc-sidebar" id="toc-sidebar">
  <div class="toc-inner">
    <h4 class="toc-title">On this page</h4>
    <nav class="toc-nav" id="toc-nav"></nav>
  </div>
</aside>

<style is:global>
  .toc-sidebar { display: none; }
  @media (min-width: 1200px) {
    .toc-sidebar {
      display: block; width: 220px; flex-shrink: 0;
    }
  }
  .toc-inner {
    position: sticky; top: 120px;
    padding-left: 24px; border-left: 1px solid rgba(255,255,255,0.08);
  }
  .toc-title {
    font-size: 1.2rem; font-weight: 600; color: rgba(255,255,255,0.4);
    text-transform: uppercase; letter-spacing: 0.05em;
    margin: 0 0 12px;
  }
  .toc-nav { display: flex; flex-direction: column; gap: 4px; }
  .toc-nav a {
    font-size: 1.25rem; color: rgba(255,255,255,0.5); text-decoration: none;
    padding: 3px 0; transition: color 0.15s; line-height: 1.35;
  }
  .toc-nav a:hover,
  .toc-nav a.active { color: var(--ghost-accent-color, #b6bdff); }
  .toc-nav a.toc-h3 { padding-left: 14px; font-size: 1.2rem; }
</style>

<script>
  (function() {
    var nav = document.getElementById('toc-nav');
    var content = document.querySelector('.gh-content');
    if (!nav || !content) return;

    var headings = content.querySelectorAll('h2, h3');
    if (headings.length < 2) return;

    var items = [];
    headings.forEach(function(h, i) {
      if (!h.id) h.id = 'heading-' + i;
      var a = document.createElement('a');
      a.href = '#' + h.id;
      a.textContent = h.textContent;
      a.className = h.tagName === 'H3' ? 'toc-h3' : '';
      a.addEventListener('click', function(e) {
        e.preventDefault();
        h.scrollIntoView({ behavior: 'smooth' });
        history.replaceState(null, '', '#' + h.id);
      });
      nav.appendChild(a);
      items.push({ el: a, heading: h });
    });

    var sidebar = document.getElementById('toc-sidebar');
    if (window.innerWidth >= 1200) sidebar.style.display = 'block';

    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        var a = items.find(function(item) { return item.heading === e.target; });
        if (a) {
          if (e.isIntersecting) {
            items.forEach(function(i) { i.el.classList.remove('active'); });
            a.el.classList.add('active');
          }
        }
      });
    }, { rootMargin: '-80px 0px -60% 0px', threshold: 0 });

    headings.forEach(function(h) { observer.observe(h); });
  })();
</script>
